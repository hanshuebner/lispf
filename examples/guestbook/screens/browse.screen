(:name "browse"
 :screen "

Author..:
Date....:
Message:
"
 :fields ((:from (1 10) :len 30 :name author :intense t :color green)
          (:from (2 10) :len 20 :name date :color turquoise)
          (:from (4 0) :len 79 :name message :repeat 16)
          (:from (20 0) :len 79 :name entry-counter :color turquoise))
 :keys ((:pf7 "Prev" :hidden t)
        (:pf8 "Next" :hidden t)
        (:pf5 "Add" :goto new-entry)
        (:pf3 "Back" :back t)))
