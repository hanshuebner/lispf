(:name "bye"
 :screen "



Thank you for visiting the Guest Book!


Session time....:
Entries written.:


"
 :fields ((:from (6 18) :len 30 :name session-time :color turquoise)
          (:from (7 18) :len 10 :name entries-written :color turquoise))
 :keys ((:enter "Logoff")
        (:pf3 "Return" :goto browse)))
